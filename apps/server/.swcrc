{
  "$schema": "https://swc.rs/schema.json",
  "sourceMaps": "inline",
  "module": { "type": "nodenext" },
  "jsc": {
    "target": "es2022",
    "keepClassNames": true,
    "parser": { "syntax": "typescript", "decorators": true },
    "transform": { "legacyDecorator": true, "decoratorMetadata": true }
  }
}
