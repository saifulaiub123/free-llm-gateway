{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import @swc-node/register/esm-register src/main.ts",
    "start": "node --import @swc-node/register/esm-register src/main.ts",
    "start:migrate": "tsx --env-file-if-exists=.env src/database/migrate.ts && node --import @swc-node/register/esm-register src/main.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file-if-exists=.env src/database/migrate.ts",
    "db:backfill-keys": "tsx --env-file-if-exists=.env scripts/backfill-user-model-keys.ts",
    "verify:postgres": "tsx scripts/verify-postgres.ts",
    "smoke": "tsx scripts/smoke-test.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.7.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.0",
    "drizzle-kit": "^0.24.0",
    "supertest": "^7.0.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^2.0.0"
  }
}
