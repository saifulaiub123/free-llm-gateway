# syntax=docker/dockerfile:1
# Builds the SvelteKit dashboard to a static SPA and serves it via nginx.
# Use with Dockerfile.server for a separate-client deployment.

ARG NODE_VERSION=22.15.0

# --- Build stage: compile the SvelteKit SPA ---------------------------------
FROM node:${NODE_VERSION}-bookworm-slim AS builder
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/* \
  && npm install -g node-gyp-build

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY apps/client/package.json ./apps/client/package.json
COPY packages/shared-types/package.json ./packages/shared-types/package.json
COPY packages/provider-adapters/package.json ./packages/provider-adapters/package.json
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm --filter client build

# --- Runtime: nginx serving the built SPA -----------------------------------
FROM nginx:stable-alpine AS runtime
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf.template
COPY --from=builder /app/apps/client/build /usr/share/nginx/html
EXPOSE 80
# Substitute __API_SERVER__ with the API_SERVER_HOST env var at container
# startup so nginx can resolve the backend at runtime.
# Set API_SERVER_HOST=http://<server-service-name>:5001 in Dokploy.
CMD ["/bin/sh", "-c", \
  "sed 's|__API_SERVER__|'\"${API_SERVER_HOST:-http://gateway:5001}\"'|g' \
   /etc/nginx/conf.d/default.conf.template > /etc/nginx/conf.d/default.conf \
   && nginx -g 'daemon off;'"]
