{
  "version": "2.0.0",
  "tasks": [
    {
      // Runs the Vite dev server for the client. Marked as a background task so the browser debug
      // config waits until Vite reports "Local: http://localhost:5173" before launching.
      "label": "dev: client",
      "type": "shell",
      "command": "pnpm --filter client dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http://localhost"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
