# Free LLM Gateway — environment template.
# Local dev: copy this file to `.env` (repo root) or `apps/server/.env`, then fill in the secrets.
# Docker/CI: provide these as real environment variables instead of a file.
# Only the SERVER reads these. The client uses VITE_ vars in apps/client/.env.* (no secrets).

# --- Server ---
PORT=5001

# --- Security (REQUIRED) ---
# 32-byte hex (64 hex chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Each at least 32 characters. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Access-token / refresh-token lifetimes (optional; sensible defaults applied).
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Database (all optional; defaults shown) ---
DB_PROVIDER=sqlite                    # sqlite | postgres
DB_URL=file:./data/llm-gateway.db     # sqlite file path, or a postgres:// connection string
DB_SCHEMA=public                      # PostgreSQL schema (ignored on SQLite)
DB_TABLE_PREFIX=                      # prepended to every table name (e.g. lg_)

# PostgreSQL example (uncomment + adjust; set DB_TABLE_PREFIX before `pnpm db:generate` if you use one):
# DB_PROVIDER=postgres
# DB_URL=postgres://gateway:gateway@localhost:5432/gateway
# DB_SCHEMA=public

# --- Routing / health (optional; defaults shown) ---
MAX_FALLBACK_ATTEMPTS=20
HEALTH_PROBE_INTERVAL_MS=300000
REQUEST_LOG_RETENTION_DAYS=90          # /v1 request logs older than this are pruned daily

# --- Request body size ---
MAX_BODY_SIZE=2mb                     # JSON body parser limit (default 1mb). Increase for large chat
                                       # completions payloads (e.g. 3-lakh-token contexts).
